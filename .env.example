# =============================================================================
# Local AI Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Ollama (primary model provider) ──────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=gemma3:1b
OLLAMA_PROMPT_BUILDER_MODEL=gemma3:1b

# ── HuggingFace (transformer models) ─────────────────────────────
HF_DEFAULT_MODEL=google/flan-t5-base
HF_MODEL_CATALOG=google/flan-t5-base,microsoft/Phi-3-mini-4k-instruct,tiiuae/falcon-rw-1b
HF_DEVICE=auto
HF_LOW_MEMORY_MODE=true
HF_ENABLE_CPU_OFFLOAD=true
HF_API_TOKEN=

# ── llama.cpp (direct GGUF inference) ────────────────────────────
LLAMACPP_N_GPU_LAYERS=-1
LLAMACPP_N_CTX=4096

# ── LM Studio / vLLM (OpenAI-compatible) ─────────────────────────
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
VLLM_BASE_URL=http://127.0.0.1:8080/v1

# ── API Server ───────────────────────────────────────────────────
API_SERVER_PORT=8000
GRADIO_SHARE=false
GRADIO_SERVER_PORT=7860

# ── Search ───────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── MCP (Model Context Protocol) ─────────────────────────────────
MCP_SERVER_URL=
MCP_TOOL_METHOD=tools/call

# ── Tracing / Debugging ──────────────────────────────────────────
TRACE_ENABLED=true
TRACE_VERBOSE=false
TRACE_STORE_DIR=./data/traces
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=local-ai-platform

# ── Memory / Context ─────────────────────────────────────────────
MAX_CONTEXT_TOKENS=4096
SMART_MEMORY_ENABLED=true

# ── Image Generation ─────────────────────────────────────────────
HF_IMAGE_MODEL_CATALOG=
HF_IMAGE_DEFAULT_MODEL=
HF_IMAGE_RUNTIME=diffusers_local
HF_IMAGE_REQUIRE_GPU=true
HF_IMAGE_ALLOW_AUTO_DOWNLOAD=false
HF_IMAGE_ALLOW_PLACEHOLDER=false
HF_IMAGE_DEVICE=auto
HF_IMAGE_ALLOW_CPU_FALLBACK=true
HF_IMAGE_JOB_TIMEOUT_SEC=180
HF_IMAGE_LOW_MEMORY_MODE=true
IMAGE_RUNTIME_STRATEGY=auto
IMAGE_MODELS_DIR=./models/image
IMAGE_BACKEND_OVERRIDE=auto
IMAGE_ENABLE_TINY_VAE=true
IMAGE_ENABLE_DEEPCACHE=true
IMAGE_ENABLE_TOME=true
IMAGE_ENABLE_QUANTIZATION=true
IMAGE_QUANTIZATION_THRESHOLD_GB=8.0
IMAGE_ENABLE_CHANNELS_LAST=true
IMAGE_ENABLE_TORCH_COMPILE=false
IMAGE_QUALITY_TIER=balanced
IMAGE_ATTENTION_BACKEND=auto
IMAGE_PREFERRED_GPU_INDEX=-1
IMAGE_ENABLE_DYNAMIC_MEMORY_CHECK=true
LOCAL_MODELS_DIR=./models
