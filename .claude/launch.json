{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Backend Server",
      "runtimeExecutable": ".venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["api_server:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Gradio Web UI",
      "runtimeExecutable": "python",
      "runtimeArgs": ["app.py"],
      "port": 7860
    },
    {
      "name": "Flutter Client (Windows)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "windows", "--dart-define=API_URL=http://127.0.0.1:8000"],
      "port": 0
    }
  ],
  "autoVerify": false
}
